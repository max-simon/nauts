[
  {
    "id": "allow-orders",
    "name": "Orders Access",
    "statements": [
      {
        "effect": "allow",
        "actions": ["nats.pub", "nats.sub"],
        "resources": ["nats:orders.>"]
      }
    ]
  },
  {
    "id": "allow-user-inbox",
    "name": "User Inbox Access",
    "statements": [
      {
        "effect": "allow",
        "actions": ["nats.pub", "nats.sub"],
        "resources": ["nats:user.{{ user.id }}.>"]
      }
    ]
  },
  {
    "id": "js-viewer",
    "name": "JetStream Viewer",
    "statements": [
      {
        "effect": "allow",
        "actions": ["js.viewer"],
        "resources": ["js:*"]
      }
    ]
  },
  {
    "id": "js-worker",
    "name": "JetStream Worker",
    "statements": [
      {
        "effect": "allow",
        "actions": ["js.worker"],
        "resources": ["js:ORDERS:*"]
      }
    ]
  },
  {
    "id": "kv-config-read",
    "name": "KV Config Read",
    "statements": [
      {
        "effect": "allow",
        "actions": ["kv.reader"],
        "resources": ["kv:config"]
      }
    ]
  },
  {
    "id": "kv-user-data",
    "name": "KV User Data",
    "statements": [
      {
        "effect": "allow",
        "actions": ["kv.writer"],
        "resources": ["kv:users:{{ user.id }}.>"]
      }
    ]
  }
]
