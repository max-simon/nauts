[
  {
    "id": "kv-config-read",
    "name": "KV Config Read",
    "statements": [
      {
        "effect": "allow",
        "actions": ["kv.reader"],
        "resources": ["kv:config"]
      }
    ]
  },
  {
    "id": "kv-user-data",
    "name": "KV User Data",
    "statements": [
      {
        "effect": "allow",
        "actions": ["kv.writer"],
        "resources": ["kv:users:{{ user.id }}.>"]
      }
    ]
  }
]
