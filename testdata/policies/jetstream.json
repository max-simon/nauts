[
  {
    "id": "js-viewer",
    "name": "JetStream Viewer",
    "statements": [
      {
        "effect": "allow",
        "actions": ["js.viewer"],
        "resources": ["js:*"]
      }
    ]
  },
  {
    "id": "js-worker",
    "name": "JetStream Worker",
    "statements": [
      {
        "effect": "allow",
        "actions": ["js.worker"],
        "resources": ["js:ORDERS:*"]
      }
    ]
  }
]
