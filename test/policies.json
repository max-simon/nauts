[
  {
    "id": "read-access",
    "name": "Read-Only Access",
    "statements": [
      {
        "effect": "allow",
        "actions": ["nats.sub"],
        "resources": ["nats:public.>"]
      }
    ]
  },
  {
    "id": "write-access",
    "name": "Write Access",
    "statements": [
      {
